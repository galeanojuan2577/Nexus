{
  "title": "NEXUS Platform",
  "uid": "nexus-platform",
  "panels": [
    {
      "title": "HTTP Requests",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(python_http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "title": "Active Devices",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
      "targets": [
        { "expr": "count(nexus_device_status == 1)" }
      ]
    },
    {
      "title": "Response Time (p99)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(python_http_request_duration_seconds_sum[5m]) / rate(python_http_request_duration_seconds_count[5m])" }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
